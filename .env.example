# ==========================================================================
# .env.example — шаблон переменных окружения
# Скопируй в .env: cp .env.example .env
# Перед первым запуском ЗАМЕНИ значения (особенно SECRET_KEY и пароли БД).
# ==========================================================================

# --- PostgreSQL ---
POSTGRES_USER=riceboard
POSTGRES_PASSWORD=change_me_before_running
POSTGRES_DB=riceboard

# URL для SQLAlchemy внутри web-контейнера.
# host=db — это имя сервиса в docker-compose, не localhost.
DATABASE_URL=postgresql+psycopg2://riceboard:change_me_before_running@db:5432/riceboard

# --- JWT ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace_me_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- FastAPI metadata ---
API_TITLE=RICEBoard API
API_VERSION=0.1.0
